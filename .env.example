# Google Gemini API Key (Required)
GOOGLE_API_KEY=your_google_api_key_here

# LangChain/LLM Settings
LLM_MODEL=gemini-2.5-flash-lite
LLM_TEMPERATURE=0.1

# Server Settings
HOST=0.0.0.0
PORT=8000

# Uvicorn Settings
RELOAD=true
UVICORN_LOG_LEVEL=info

# Application Logging
LOG_LEVEL=INFO

# JWT Configuration (Required)
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# gRPC (shared for multiple workflows)
GRPC_ENABLED=false
GRPC_URL=103.20.96.59:5000
GRPC_TIMEOUT_SECONDS=3
