# ====================================
# AI SERVICE - ENVIRONMENT VARIABLES (TEMPLATE)
# ====================================

# ====================================
# API Configuration
# ====================================
APP_NAME=AI Service
APP_VERSION=3.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000
RELOAD=true
UVICORN_LOG_LEVEL=info
LOG_LEVEL=INFO

# ====================================
# Google Gemini API Key (Required)
# ====================================
GOOGLE_API_KEY=your_google_api_key_here

# ====================================
# LLM Configuration (Classification & Extraction)
# ====================================
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.1
# Options: none, low, medium, high
LLM_THINKING_LEVEL=low

# Gemini Request Limits
GENAI_REQUEST_TIMEOUT=90

# ====================================
# Gemini RAG Chat Configuration
# ====================================
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

GEMINI_TEMPERATURE=0.3
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40
GEMINI_TIMEOUT_SECONDS=60
AGENT_MAX_TURNS=7

# ====================================
# LlamaParse Configuration
# ====================================
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here
LLAMA_PARSE_RESULT_TYPE=markdown
LLAMA_PARSE_LANGUAGE=vi
LLAMA_PARSE_USE_PREMIUM=false

# ====================================
# Qdrant Vector DB Configuration
# ====================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=file_overviews
QDRANT_TOP_K=15
QDRANT_MIN_SCORE=0.2
RETRIEVAL_MIN_DOC_SCORE=1.0
QDRANT_VECTOR_SIZE=3072

# ====================================
# PageIndex Configuration
# ====================================
# Local path or relative path to store structural document data
PAGEINDEX_WORKSPACE=storage/pageindex_workspace
PAGEINDEX_MODEL=gemini-2.5-flash
PAGEINDEX_RETRIEVE_MODEL=gemini-2.5-flash
PAGEINDEX_TOC_CHECK_PAGE_NUM=20
PAGEINDEX_MAX_PAGE_NUM_EACH_NODE=10
PAGEINDEX_MAX_TOKEN_NUM_EACH_NODE=20000
PAGEINDEX_SUMMARY_TOKEN_THRESHOLD=200
PAGEINDEX_IF_ADD_NODE_ID=yes
PAGEINDEX_IF_ADD_NODE_SUMMARY=yes
PAGEINDEX_IF_ADD_DOC_DESCRIPTION=no
PAGEINDEX_IF_ADD_NODE_TEXT=no

# ====================================
# FAQ Configuration
# ====================================
FAQ_QDRANT_COLLECTION=faqs
FAQ_SEMANTIC_THRESHOLD=0.90
FAQ_SYNTHESIS_CLUSTERING_THRESHOLD=0.85
FAQ_SYNTHESIS_ENABLED=false
FAQ_SYNTHESIS_INTERVAL_DAYS=7
FAQ_SYNTHESIS_MIN_CLUSTER_SIZE=10
FAQ_SYNTHESIS_LOOKBACK_DAYS=30
FAQ_LOG_RETENTION_DAYS=90
FAQ_LOG_MIN_QUESTION_LENGTH=15

# ====================================
# MongoDB Configuration (Required)
# ====================================
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/ai_service
MONGODB_DB_NAME=ai_service
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_POOL_SIZE=100

# ====================================
# Cloudflare R2 / S3 Configuration (Required)
# ====================================
R2_ENDPOINT=localhost:9000
R2_ACCESS_KEY=r2admin
# In production, use a secure secret
R2_SECRET_KEY=r2admin
R2_BUCKET_NAME=rag-files
R2_USE_SSL=false
R2_REGION=us-east-1
R2_PUBLIC_DOMAIN=https://pub-your-custom-domain.r2.dev

# ====================================
# RabbitMQ Configuration (Email Ingestion)
# ====================================
RABBITMQ_ENABLED=true
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_INGEST_QUEUE=email_ingest_queue
RABBITMQ_EMAIL_DLX=email_ingest_dlx
RABBITMQ_EMAIL_DLQ=email_ingest_dlq
RABBITMQ_EMAIL_MAX_RETRIES=1

# ====================================
# Redis Configuration (Shared Cache)
# ====================================
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_TIMEOUT=5

# ====================================
# gRPC Configuration (Integration with nest-api)
# ====================================
GRPC_ENABLED=false
GRPC_URL=localhost:5000
GRPC_TIMEOUT_SECONDS=3.0

# ====================================
# JWT Local Verification Configuration
# ====================================
JWT_SECRET=CHANGE_ME_SUPER_SECRET
JWT_TOKEN_AUDIENCE=vaa
JWT_TOKEN_ISSUER=vaa-api

# ====================================
# File Upload Configuration
# ====================================
MAX_FILE_SIZE_MB=20

# ====================================
# Rate Limiting
# ====================================
MAX_REQUESTS_PER_MINUTE=60

# ====================================
# CORS Configuration
# ====================================
# Comma-separated list (e.g., http://localhost:3000,https://app.example.com)
CORS_ORIGINS=["*"]
