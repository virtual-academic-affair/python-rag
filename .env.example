# ====================================
# AI SERVICE - ENVIRONMENT VARIABLES
# ====================================

# ====================================
# Google Gemini API Key (Required)
# ====================================
GOOGLE_API_KEY=your_google_api_key_here

# ====================================
# LLM Configuration
# ====================================
# Classification settings
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.1
LLM_THINKING_LEVEL=1

# Gemini Request Limits
GENAI_REQUEST_TIMEOUT=60
GENAI_MAX_OUTPUT_TOKENS_CLASSIFICATION=100
GENAI_MAX_OUTPUT_TOKENS_EXTRACTION=1200

# RAG chat settings
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.3
GEMINI_MAX_OUTPUT_TOKENS=2048
GEMINI_TOP_P=0.95
GEMINI_TOP_K=40
GEMINI_TIMEOUT_SECONDS=60

# ====================================
# MongoDB Configuration (Required)
# ====================================
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_DB_NAME=ai_service
MONGODB_MIN_POOL_SIZE=10
MONGODB_MAX_POOL_SIZE=100

# ====================================
# MinIO/S3 Configuration (Required)
# ====================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=rag-files
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# ====================================
# RabbitMQ Configuration
# ====================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# gRPC (shared for multiple workflows)
GRPC_ENABLED=false
GRPC_URL=103.20.96.59:5000
GRPC_TIMEOUT_SECONDS=3
RABBITMQ_INGEST_QUEUE=email_ingest_queue

# ====================================
# Server Configuration
# ====================================
HOST=0.0.0.0
PORT=8000
RELOAD=true
UVICORN_LOG_LEVEL=info
LOG_LEVEL=INFO
DEBUG=false

# ====================================
# File Upload Configuration
# ====================================
MAX_FILE_SIZE_MB=20
ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.txt,.md,.html

# ====================================
# Chunking Configuration
# ====================================
CHUNKING_ENABLED=false
CHUNKING_MAX_TOKENS_PER_CHUNK=200
CHUNKING_MAX_OVERLAP_TOKENS=20

# ====================================
# Rate Limiting
# ====================================
MAX_REQUESTS_PER_MINUTE=60

# ====================================
# CORS Configuration
# ====================================
# CORS_ORIGINS=*  # Use comma-separated list in production

# ====================================
# API Configuration
# ====================================
APP_NAME=AI Service
APP_VERSION=3.0.0
