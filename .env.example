# ====================================
# AI SERVICE - ENVIRONMENT VARIABLES (TEMPLATE)
# ====================================

# ====================================
# API Configuration
# ====================================
APP_NAME=AI Service
APP_VERSION=5.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000
RELOAD=true
UVICORN_LOG_LEVEL=info
LOG_LEVEL=INFO

# ====================================
# Application URLs
# ====================================
DOCUMENT_VIEW_URL_PREFIX=https://vaa.hcmus.app/?viewDocumentId=

# ====================================
# Shared LLM Provider Configuration
# ====================================
LLM_API_KEY=your_llm_provider_api_key_here
LLM_MODEL=gemini/gemini-2.5-flash
LLM_TIMEOUT_SECONDS=60
LLM_MAX_ATTEMPTS=3
LLM_DETERMINISTIC_TEMPERATURE=0.0
LLM_DIRECT_REPLY_TEMPERATURE=0.5

# ====================================
# LlamaParse Configuration
# ====================================
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here
LLAMA_PARSE_RESULT_TYPE=markdown
LLAMA_PARSE_LANGUAGE=vi
LLAMA_PARSE_USE_PREMIUM=false

# ====================================
# PageIndex Configuration
# ====================================
# Local path or relative path to store structural document data
PAGEINDEX_WORKSPACE=storage/pageindex_workspace
PAGEINDEX_AGENT_MAX_TURNS=7
PAGEINDEX_TOC_CHECK_PAGE_NUM=20
PAGEINDEX_MAX_PAGE_NUM_EACH_NODE=10
PAGEINDEX_MAX_TOKEN_NUM_EACH_NODE=20000
PAGEINDEX_SUMMARY_TOKEN_THRESHOLD=200
PAGEINDEX_IF_ADD_NODE_ID=yes
PAGEINDEX_IF_ADD_NODE_SUMMARY=yes
PAGEINDEX_IF_ADD_DOC_DESCRIPTION=no
PAGEINDEX_IF_ADD_NODE_TEXT=no
PAGEINDEX_DOC_CACHE_TTL_SECONDS=3600
PAGEINDEX_MARKDOWN_CACHE_TTL_SECONDS=3600

# ====================================
# Cohere Rerank Configuration
# ====================================
COHERE_API_KEY=your_cohere_api_key_here
COHERE_RERANK_ENABLED=true
COHERE_RERANK_MODEL=rerank-v4.0-fast
COHERE_RERANK_MAX_CANDIDATES=1000
COHERE_RERANK_FILE_TOP_N=5
COHERE_RERANK_FAQ_TOP_N=3
COHERE_RERANK_MAX_TOKENS_PER_DOC=1024
COHERE_RERANK_TIMEOUT_SECONDS=10.0

# ====================================
# Agentic Corpus Tree traversal
# ====================================
CORPUS_TRAVERSAL_MAX_TURNS=10
CORPUS_TRAVERSAL_MAX_SELECTED_TOPICS=5
CORPUS_TRAVERSAL_SOFT_FILE_LIMIT=100
CORPUS_TRAVERSAL_SOFT_FAQ_LIMIT=50
CORPUS_TRAVERSAL_TOPIC_SAMPLE_LIMIT=5

# ====================================
# MongoDB Configuration (Required)
# ====================================
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/ai_service
MONGODB_DB_NAME=ai_service
MONGODB_MIN_POOL_SIZE=1
MONGODB_MAX_POOL_SIZE=20

# ====================================
# Cloudflare R2 / S3 Configuration (Required)
# ====================================
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY=r2admin
# In production, use a secure secret
R2_SECRET_KEY=r2admin
R2_BUCKET_NAME=rag-files
R2_REGION=us-east-1
R2_PUBLIC_DOMAIN=

# ====================================
# RabbitMQ Configuration (Email Ingestion)
# ====================================
RABBITMQ_ENABLED=true
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_INGEST_QUEUE=email_ingest_queue
RABBITMQ_EMAIL_DLX=email_ingest_dlx
RABBITMQ_EMAIL_DLQ=email_ingest_dlq
RABBITMQ_EMAIL_MAX_RETRIES=1

# ====================================
# Redis Configuration (Shared Cache)
# ====================================
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379/0
REDIS_TIMEOUT=5
RAG_CORPUS_CACHE_TTL_SECONDS=300
RAG_ALLOWED_IDS_CACHE_TTL_SECONDS=120
RAG_ENTITY_CACHE_TTL_SECONDS=600

# ====================================
# gRPC Configuration (Integration with nest-api)
# ====================================
GRPC_ENABLED=false
GRPC_URL=localhost:5000
GRPC_TIMEOUT_SECONDS=3.0

# ====================================
# JWT Local Verification Configuration
# ====================================
JWT_SECRET=CHANGE_ME_SUPER_SECRET
JWT_TOKEN_AUDIENCE=vaa
JWT_TOKEN_ISSUER=vaa-api

# ====================================
# File Upload Configuration
# ====================================
MAX_FILE_SIZE_MB=20

# ====================================
# CORS Configuration
# ====================================
# Comma-separated list (e.g., http://localhost:3000,https://app.example.com)
CORS_ORIGINS=["*"]
